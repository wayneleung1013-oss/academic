---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import UploadForm from "../components/UploadForm.astro";

const uploadItems = [
  "原始稿件（Word / LaTeX / PDF）",
  "目标期刊模板",
  "author guidelines 文件",
  "图表文件",
  "参考文献文件",
  "补充材料",
];
---

<BaseLayout
  title="上传稿件"
  description="向 ScholarFormat Studio 上传稿件文件获取报价：支持 Word、LaTeX、PDF、图片、模板或压缩包。文件仅用于本次排版服务，不会公开展示或用于其他用途。"
>
  <PageHeader
    eyebrow="Upload Manuscript"
    title="上传稿件"
    titleEn="Upload your files for a quote"
    lead="请上传 Word、LaTeX、PDF、图片、模板或压缩包文件。文件仅用于本次排版服务，不会公开展示或用于其他用途。"
  />

  <Section>
    <div class="upload-layout">
      <div class="upload-main">
        <UploadForm />
      </div>

      <aside class="upload-aside">
        <div class="info-card">
          <h2 class="info-card__title">可以一起上传</h2>
          <ul class="info-list">
            {
              uploadItems.map((item) => (
                <li class="info-list__item">
                  <Icon name="check" size={18} class="info-list__icon" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="info-card">
          <h2 class="info-card__title">
            <Icon name="lock" size={18} class="info-card__icon" />
            文件保密
          </h2>
          <p class="info-card__text">
            文件仅用于本次排版服务，不会公开展示、不用于案例宣传，除非获得你的明确授权。
          </p>
        </div>

        <div class="info-card">
          <h2 class="info-card__title">不方便上传？</h2>
          <p class="info-card__text">
            如果暂时不便上传文件，可先通过联系表单说明需求，我们会与你确认后续方式。
          </p>
          <Button href="/contact" variant="secondary" icon="arrowRight">改用联系表单</Button>
        </div>
      </aside>
    </div>
  </Section>
</BaseLayout>

<style>
  .upload-layout {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(var(--space-6), 3vw, var(--space-8));
    align-items: start;
  }

  .upload-aside {
    position: sticky;
    top: calc(var(--header-height) + var(--space-4));
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .info-card {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }

  .info-card__title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-md);
    font-weight: var(--weight-semibold);
    color: var(--color-ink);
    margin: 0;
  }

  .info-card__icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .info-card__text {
    margin: var(--space-3) 0 0;
    color: var(--color-ink-2);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .info-card__text + :global(.btn) {
    margin-top: var(--space-4);
  }

  .info-list {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .info-list__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    color: var(--color-ink-2);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  .info-list__icon {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  @media (max-width: 900px) {
    .upload-layout {
      grid-template-columns: 1fr;
    }
    .upload-aside {
      position: static;
    }
  }
</style>
