---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import ServiceDetail from "../components/ServiceDetail.astro";
import CTABanner from "../components/CTABanner.astro";
import { services } from "../content/services";

const authorServices = services.filter((s) => s.audience === "author");
const institutionServices = services.filter((s) => s.audience === "institution");
---

<BaseLayout
  title="服务"
  description="ScholarFormat Studio 的六项学术论文排版与出版服务：基础期刊格式排版、标准投稿排版、技术论文 / LaTeX 排版、期刊文章出版排版、期刊 / 会议批量排版、JATS XML 生成 / 转换。"
>
  <PageHeader
    eyebrow="服务"
    eyebrowEn="Services"
    title="服务"
    titleEn="What we format & deliver"
    lead="ScholarFormat Studio 提供六项学术论文排版与出版服务，覆盖从个人投稿到期刊出版的完整流程。请提供目标期刊 / 会议与投稿指南，我们按要求排版。"
  />

  <nav class="svc-nav" aria-label="服务快捷导航">
    <div class="container">
      <p class="svc-nav__label">快捷导航</p>
      <ul class="svc-nav__grid">
        {
          services.map((s, i) => (
            <li>
              <a class="svc-nav__chip" href={"#" + s.id}>
                <span class="svc-nav__num">{String(i + 1).padStart(2, "0")}</span>
                <span class="svc-nav__name">{s.nameZh}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  <Section
    eyebrow="个人作者"
    title="面向个人作者的排版服务"
    lead="适合准备投稿期刊或会议的研究者，按目标期刊投稿指南完成排版，交付 Word / LaTeX 与 PDF 文件。"
  >
    <div class="svc-stack">
      {
        authorServices.map((s) => (
          <ServiceDetail service={s} index={services.indexOf(s)} />
        ))
      }
    </div>
  </Section>

  <Section
    variant="subtle"
    eyebrow="机构客户"
    title="面向期刊 / 会议 / 编辑部的服务"
    lead="面向编辑部、出版社、会议与协会，提供录用后出版排版、批量排版与结构化 JATS XML 转换。"
  >
    <div class="svc-stack">
      {
        institutionServices.map((s) => (
          <ServiceDetail service={s} index={services.indexOf(s)} />
        ))
      }
    </div>
  </Section>

  <CTABanner />
</BaseLayout>

<style>
  .svc-nav {
    padding-block: var(--space-6);
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-line);
  }
  .svc-nav__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: var(--space-3);
  }
  .svc-nav__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .svc-nav__chip {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    height: 100%;
    padding: 0.7rem 0.95rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    color: var(--color-ink-2);
    text-decoration: none;
    font-size: var(--text-sm);
    box-shadow: var(--shadow-xs);
    transition: var(--transition);
  }
  .svc-nav__chip:hover {
    border-color: var(--color-primary);
    color: var(--color-primary-strong);
    box-shadow: var(--shadow-sm);
  }
  .svc-nav__num {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.04em;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .svc-nav__name {
    font-weight: var(--weight-medium);
  }

  .svc-stack {
    display: grid;
    gap: 1.5rem;
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(html) {
      scroll-behavior: smooth;
    }
  }
</style>
