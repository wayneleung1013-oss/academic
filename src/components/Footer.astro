---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { site } from "../config/site";
import { footerNav } from "../content/nav";

const year = 2026; // 如需自动年份，可在构建时注入；此处固定以保证静态可复现。
const { email, wechat, whatsapp } = site.contact;
const hasContact = Boolean(email || wechat || whatsapp);
---

<footer class="site-footer">
  <div class="container site-footer__top">
    <div class="site-footer__brand">
      <Logo variant="invert" />
      <p class="site-footer__tagline">{site.tagline}</p>
      <p class="site-footer__desc">
        ScholarFormat Studio 专注学术论文投稿排版，为科研作者、学生作者、期刊与会议提供 Word /
        LaTeX 排版、投稿文件整理、PDF production 与 JATS XML 生成服务。
      </p>

      {
        hasContact ? (
          <ul class="site-footer__contact">
            {email && (
              <li>
                <Icon name="mail" size={16} />
                <a href={`mailto:${email}`}>{email}</a>
              </li>
            )}
            {wechat && (
              <li>
                <Icon name="chat" size={16} />
                <span>微信：{wechat}</span>
              </li>
            )}
            {whatsapp && (
              <li>
                <Icon name="phone" size={16} />
                <span>WhatsApp：{whatsapp}</span>
              </li>
            )}
          </ul>
        ) : (
          <p class="site-footer__contact-soon">请通过联系表单提交需求，我们会尽快回复。</p>
        )
      }
    </div>

    <div class="site-footer__links">
      {
        footerNav.map((col) => (
          <nav class="site-footer__col" aria-label={col.title}>
            <h3>{col.title}</h3>
            <ul>
              {col.items.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">
      <p>© {year} {site.brand}</p>
      <p class="site-footer__operated">{site.tagline}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    background: var(--color-ink);
    color: rgba(255, 255, 255, 0.78);
    font-size: var(--text-sm);
  }
  .site-footer__top {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 2fr);
    gap: clamp(2rem, 1rem + 4vw, 4rem);
    padding-block: clamp(2.5rem, 1.5rem + 3vw, 4rem);
  }

  .site-footer__tagline {
    margin-top: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    font-style: italic;
  }
  .site-footer__desc {
    margin-top: 0.8rem;
    line-height: var(--leading-relaxed);
    max-width: 42ch;
  }

  .site-footer__contact {
    margin-top: 1.2rem;
    display: grid;
    gap: 0.55rem;
  }
  .site-footer__contact li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .site-footer__contact a {
    color: #fff;
  }
  .site-footer__contact a:hover {
    color: var(--color-accent);
  }
  .site-footer__contact-soon {
    margin-top: 1.2rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .site-footer__links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .site-footer__col h3 {
    color: #fff;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    margin-bottom: 0.9rem;
    letter-spacing: 0.02em;
  }
  .site-footer__col ul {
    display: grid;
    gap: 0.55rem;
  }
  .site-footer__col a {
    color: rgba(255, 255, 255, 0.72);
  }
  .site-footer__col a:hover {
    color: #fff;
  }

  .site-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .site-footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1.5rem;
    padding-block: 1.4rem;
    color: rgba(255, 255, 255, 0.55);
    font-size: var(--text-xs);
  }

  @media (max-width: 760px) {
    .site-footer__top {
      grid-template-columns: 1fr;
    }
    .site-footer__links {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 440px) {
    .site-footer__links {
      grid-template-columns: 1fr;
    }
  }
</style>
