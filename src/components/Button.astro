---
import Icon from "./Icon.astro";

/**
 * 通用按钮 / 链接按钮。
 * <Button href="/contact" variant="primary" icon="arrowRight">获取报价</Button>
 */
export interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost" | "white";
  size?: "md" | "lg";
  icon?: string;
  iconPosition?: "left" | "right";
  type?: "button" | "submit" | "reset";
  class?: string;
  fullWidth?: boolean;
  [key: string]: unknown;
}

const {
  href,
  variant = "primary",
  size = "md",
  icon,
  iconPosition = "right",
  type = "button",
  class: className = "",
  fullWidth = false,
  ...rest
} = Astro.props;

const Tag = href ? "a" : "button";
const classes = [
  "btn",
  `btn--${variant}`,
  `btn--${size}`,
  fullWidth ? "btn--block" : "",
  className,
]
  .filter(Boolean)
  .join(" ");

const tagProps = href ? { href } : { type };
---

<Tag class={classes} {...tagProps} {...rest}>
  {icon && iconPosition === "left" && <Icon name={icon} size={size === "lg" ? 20 : 18} />}
  <span><slot /></span>
  {icon && iconPosition === "right" && <Icon name={icon} size={size === "lg" ? 20 : 18} />}
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    line-height: 1;
    border-radius: var(--radius-md);
    border: 1.5px solid transparent;
    transition:
      background-color var(--transition),
      border-color var(--transition),
      color var(--transition),
      transform var(--transition-fast),
      box-shadow var(--transition);
    white-space: nowrap;
    text-align: center;
    cursor: pointer;
  }
  .btn:hover {
    transform: translateY(-1px);
  }
  .btn:active {
    transform: translateY(0);
  }

  .btn--md {
    padding: 0.7rem 1.25rem;
  }
  .btn--lg {
    padding: 0.9rem 1.7rem;
    font-size: var(--text-md);
  }
  .btn--block {
    width: 100%;
  }

  /* Primary —— 学术蓝实心 */
  .btn--primary {
    background: var(--color-primary);
    color: #fff;
    box-shadow: var(--shadow-sm);
  }
  .btn--primary:hover {
    background: var(--color-primary-strong);
    color: #fff;
    box-shadow: var(--shadow-md);
  }

  /* Secondary —— 描边 */
  .btn--secondary {
    background: #fff;
    color: var(--color-primary);
    border-color: var(--color-line-strong);
  }
  .btn--secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary-strong);
    background: var(--color-primary-soft);
  }

  /* Ghost —— 透明文字按钮 */
  .btn--ghost {
    background: transparent;
    color: var(--color-ink-2);
  }
  .btn--ghost:hover {
    background: var(--color-bg-soft);
    color: var(--color-ink);
  }

  /* White —— 深色背景上的白色按钮 */
  .btn--white {
    background: #fff;
    color: var(--color-primary-strong);
  }
  .btn--white:hover {
    background: #eef3fb;
    color: var(--color-primary-strong);
  }
</style>
