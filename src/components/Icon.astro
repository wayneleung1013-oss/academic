---
/**
 * 内联 SVG 图标（不依赖任何图标字体 / 外部 CDN，国内可正常加载）。
 * 用法：<Icon name="check" size={20} />
 */
export interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}

const { name, size = 24, class: className = "", strokeWidth = 1.7 } = Astro.props;

const icons: Record<string, string> = {
  // 卖点 / 服务图标
  target: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.4"/>',
  file: '<path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M6 3h8l5 5v11a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/><path d="M9 13h6"/><path d="M9 17h4"/>',
  guidelines: '<rect x="8" y="3" width="8" height="4" rx="1"/><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><path d="m9 14 2 2 4-4"/>',
  anonymous: '<path d="M10.7 5.1A9 9 0 0 1 12 5c3.6 0 7 2.5 9 6a14 14 0 0 1-1.7 2.4"/><path d="M6.3 6.3A14 14 0 0 0 3 11c2 3.5 5.4 6 9 6 1.4 0 2.7-.3 3.9-.9"/><path d="m2 2 20 20"/><path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"/>',
  pdf: '<path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M6 3h8l5 5v12a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/><path d="M12 11v6"/><path d="m9.5 14.5 2.5 2.5 2.5-2.5"/>',
  xml: '<path d="m8 8-4 4 4 4"/><path d="m16 8 4 4-4 4"/><path d="M13.5 6 10.5 18"/>',
  lock: '<rect x="4.5" y="11" width="15" height="9.5" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
  shield: '<path d="M12 3 5 6v5c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6z"/><path d="m9.3 12 1.9 1.9L15 10.2"/>',
  format: '<path d="M4 6h16"/><path d="M4 12h10"/><path d="M4 18h13"/>',
  submit: '<path d="M22 3 11 14"/><path d="M22 3 15 21l-4-7-7-4z"/>',
  latex: '<path d="M18 7V4H6l6 8-6 8h12v-3"/>',
  production: '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 8h8"/><path d="M8 12h8"/><path d="M8 16h5"/>',
  batch: '<rect x="8" y="3" width="13" height="13" rx="2"/><path d="M5 8a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2"/>',
  // UI 图标
  check: '<path d="M20 6 9 17l-5-5"/>',
  x: '<path d="M18 6 6 18"/><path d="M6 6l12 12"/>',
  arrowRight: '<path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>',
  chevronDown: '<path d="m6 9 6 6 6-6"/>',
  menu: '<path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  chat: '<path d="M21 11.5a8 8 0 0 1-11.5 7.2L4 20l1.3-4.5A8 8 0 1 1 21 11.5z"/>',
  phone: '<path d="M6.6 3.5 9 4l1 4-2 1.5a11 11 0 0 0 5 5L14 12l4 1 .5 2.4a2 2 0 0 1-2 2.6A15 15 0 0 1 4 5a2 2 0 0 1 2.6-1.5z"/>',
  upload: '<path d="M12 15V4"/><path d="m7.5 8.5 4.5-4.5 4.5 4.5"/><path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  quote: '<path d="M7.5 7C6 8 5 9.8 5 12v5h5v-5H8c0-1.5.6-2.6 2-3.3zM18 7c-1.5 1-2.5 2.8-2.5 5v5h5v-5h-2c0-1.5.6-2.6 2-3.3z"/>',
  star: '<path d="m12 3 2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.9 6.8 19.6l1-5.8L3.5 9.7l5.9-.9z"/>',
};

const path = icons[name] ?? "";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`icon ${className}`}
  aria-hidden="true"
  focusable="false"
  set:html={path}
/>

<style>
  .icon {
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
</style>
