# Mail settings for /api/contact and /api/upload.
# Do not commit real passwords. Copy this file to .env and fill in real values locally/deploy env vars.

SITE_URL=https://scholarformatstudio.com
MAIL_PROVIDER=resend
RESEND_API_KEY=
SMTP_HOST=smtp.resend.com
SMTP_HOST_IP=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
# Optional fallback if RESEND_API_KEY is empty. Keep only one real key in production.
SMTP_PASS=
SMTP_FROM="ScholarFormat Studio <sfs@scholarformatstudio.com>"
CONTACT_NOTIFY_TO=sfs@scholarformatstudio.com
UPLOAD_NOTIFY_TO=sfs@scholarformatstudio.com

# Optional SMTP fallback settings. Not needed when MAIL_PROVIDER=resend uses HTTPS API.
# Examples:
# SMTP_PROXY=http://127.0.0.1:7890
# SMTP_PROXY=socks5://127.0.0.1:7891
SMTP_PROXY=
