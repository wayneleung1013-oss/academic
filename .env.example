# SMTP settings for /api/upload.
# Do not commit real passwords. Copy this file to .env and fill in real values locally/deploy env vars.

SMTP_HOST=smtp.example.com
# Optional. Use only when local DNS/Fake-IP breaks SMTP_HOST resolution.
SMTP_HOST_IP=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM="ScholarFormat Studio <your-smtp-user@example.com>"
UPLOAD_NOTIFY_TO=sfs@scholarformatstudio.com

# Optional. Use this when local/prod network blocks SMTP ports or uses Fake-IP DNS.
# Examples:
# SMTP_PROXY=http://127.0.0.1:7890
# SMTP_PROXY=socks5://127.0.0.1:7891
SMTP_PROXY=
